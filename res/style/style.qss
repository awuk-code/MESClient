/* ============================================================
   全局基础样式
   说明：这里只放通用 QWidget 控件样式，页面差异通过 objectName
   或动态属性（例如 buttonRole、labelRole、panelRole）区分。
   ============================================================ */

QPushButton {
    background-color: transparent;
    border: none;
    font-size: 13px;
}

QToolButton {
    border: none;
    background: transparent;
}

QLabel,
QLineEdit,
QComboBox,
QTextEdit,
QRadioButton,
QCheckBox {
    font-size: 13px;
}

QToolTip {
    border: 1px solid #dcdcdc;
    background-color: #ffffff;
    color: #f10202;
    font-size: 12px;
    padding: 2px;
}

/* ============================================================
   顶部栏、侧边栏、二级导航
   ============================================================ */

#HeaderWidget {
    background-color: #808;
    border-bottom: 1px solid #e8e8e8;
}

#SideBarWidget {
    background-color: #e0e6ed;
    border-right: 1px solid #e8edf1;
}

#SubHeaderWidget {
    background-color: #ffffff;
    border-bottom: 1px solid #e8e8e8;
}

#SubHeaderWidget QLabel {
    color: #666666;
    font-size: 13px;
}

/* 侧边栏菜单按钮 */
#menuBtn {
    background-color: transparent;
    border: none;
    color: #000000;
    font-size: 12px;
    font-weight: bold;
    padding: 0px;
    border-radius: 4px;
}

#menuBtn:checked {
    background-color: #f7e8f7;
    color: #880088;
}

#menuBtn:hover {
    background-color: #f5f7fa;
    color: #880088;
}

/* ============================================================
   通用业务页面：页签、表格、按钮、信息字段
   ============================================================ */

QTabBar#BasePageTabBar {
    border-top: 1px solid #dcdfe6;
}

QTabBar#BasePageTabBar::tab {
    background: transparent;
    font-size: 13px;
    height: 40px;
    padding: 0px 20px;
    margin-top: 1px;
    color: #606266;
    border: none;
}

QTabBar#BasePageTabBar::tab:selected {
    color: #880088;
    border-top: 2px solid #880088;
}

QTabBar#BasePageTabBar::tab:hover {
    color: #880088;
}


/* 标题等级：软件最大标题。以后修改系统标题字体、字号、颜色，优先改这里。 */
QLabel[labelRole="appTitle"] {
    font-size: 18px;
    font-weight: 700;
    color: #ffffff;
}

/* 标题等级：页面一级标题。以后修改页面标题字体、字号、颜色，优先改这里。 */
QLabel[labelRole="pageTitle"],
QLabel[labelRole="dialogTitle"] {
    font-size: 16px;
    font-weight: 700;
    color: #303133;
}

QLabel[labelRole="fieldName"] {
    font-size: 13px;
    color: #606266;
}

QLabel[labelRole="fieldValue"] {
    font-size: 13px;
    color: #303133;
}

/* 标题等级：区域二级标题。以后修改左侧标题、内容区标题字体，优先改这里。 */
QLabel[labelRole="sectionTitle"] {
    padding-left: 12px;
    font-size: 14px;
    font-weight: 600;
    color: #303133;
    border: none;
    border-bottom: 1px solid #dcdfe6;
}

QLabel[labelRole="imageLink"] {
    color: #880088;
}

/* 表格正文样式入口：表格内容字体、颜色在这里统一设置，表头和代理绘制样式不在这里处理。 */
QTableView {
    font-size: 13px;
    color: #303133;
}

QHeaderView::section {
    font-size: 13px;
}

QFrame[panelRole="section"] {
    background: #ffffff;
    border: 1px solid #dcdfe6;
}

QFrame[panelRole="pageContent"] {
    background: #ffffff;
    border: 1px solid #dcdfe6;
}

QToolButton[buttonRole="panelToggle"] {
    border: none;
    background: transparent;
    padding: 0px;
}

/* ============================================================
   自定义弹窗：BaseDialogWidget 统一由标题区、内容区、按钮区三部分组成。
   后续修改弹窗标题背景、边框、关闭按钮样式时优先改这里。
   ============================================================ */

QDialog#BaseDialogWidget {
    background-color: #ffffff;
    border: 1px solid #dcdfe6;
}

QDialog#BaseDialogWidget QWidget#DialogTitleBar {
    background-color: #808;
    border-bottom: 1px solid #6f006f;
}

QDialog#BaseDialogWidget QWidget#DialogTitleBar QLabel[labelRole="dialogTitle"] {
    color: #ffffff;
}

QDialog#BaseDialogWidget QPushButton#DialogCloseButton {
    background-color: transparent;
    border: none;
    padding: 0px;
}

QDialog#BaseDialogWidget QPushButton#DialogCloseButton:hover {
    background-color: rgba(255, 255, 255, 45);
    border-radius: 4px;
}

QDialog#BaseDialogWidget QWidget#DialogContent {
    background-color: #ffffff;
}

QDialog#BaseDialogWidget QWidget#DialogButtonBar {
    background-color: #ffffff;
    border-top: 1px solid #ebeef5;
}

QPushButton[buttonRole="save"],
QPushButton[buttonRole="export"],
QPushButton[buttonRole="primary"] {
    background-color: #880088;
    color: #ffffff;
    border-radius: 4px;
    padding: 6px 16px;
}

QPushButton[buttonRole="save"]:hover,
QPushButton[buttonRole="export"]:hover,
QPushButton[buttonRole="primary"]:hover {
    background-color: #a64ca6;
}

QPushButton[buttonRole="save"]:disabled,
QPushButton[buttonRole="export"]:disabled,
QPushButton[buttonRole="primary"]:disabled {
    background-color: #c0c4cc;
    color: #ffffff;
}

QPushButton[buttonRole="secondary"] {
    background-color: #ffffff;
    color: #303133;
    border: 1px solid #dcdfe6;
    border-radius: 4px;
    padding: 6px 16px;
}

QPushButton[buttonRole="secondary"]:hover {
    color: #880088;
    border-color: #880088;
}

QPushButton[buttonRole="link"] {
    color: #880088;
    text-align: left;
    border: none;
    background: transparent;
    padding: 0px;
}

QPushButton[buttonRole="compact"] {
    background-color: transparent;
    color: #303133;
    border-radius: 4px;
    padding: 4px 10px;
    min-height: 24px;
}

QPushButton[buttonRole="compact"]:hover {
    background-color: #f0f2f5;
}

QPushButton[buttonRole="compact"]:pressed,
QPushButton[buttonRole="compact"]:checked {
    background-color: #880088;
    color: #ffffff;
}

QPushButton[buttonRole="compact"]:disabled {
    color: #c0c4cc;
    background-color: transparent;
}

/* ============================================================
   登录窗口
   ============================================================ */

#MLoginWidget QLineEdit {
    border: 1px solid #cccccc;
    border-radius: 5px;
    padding: 6px;
}

#MLoginWidget QLineEdit:hover {
    border: 1px solid #880088;
}

#MLoginWidget QPushButton#LoginBtn {
    background-color: #880088;
    color: #ffffff;
    border-radius: 5px;
}

#MLoginWidget QPushButton#LoginBtn:hover {
    background-color: #a64ca6;
}

#LoginErrorLabel {
    color: #ff0000;
}
